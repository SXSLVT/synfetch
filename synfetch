            printf '\e[%d;%dH' $((warn_row+1)) $((warn_col+1))
            echo -e "${C1}-- TERMINAL TOO SMALL --${RESET}"
            printf '\e[%d;%dH' $((warn_row+2)) $((warn_col+1))
            echo -e "   Need at least вҶ’ ${YELLOW}120 Г— 26${RESET}"
            printf '\e[%d;%dH' $((warn_row+3)) $((warn_col+1))
            echo -e "   You have      вҶ’ ${GRAY}${cols} Г— ${lines}${RESET}"
            printf '\e[%d;%dH' $((warn_row+4)) $((warn_col+1))
            echo -e "${GRAY}Ctrl+C to exit synfetch --live${RESET}"
            WAS_TOO_SMALL=true
            sleep 0.5
            continue
        fi

        if [ "$cols" != "$LAST_COLS" ] || [ "$lines" != "$LAST_LINES" ] || [ "$WAS_TOO_SMALL" = true ] || [[ "$SHOW_RIGHT_PANEL" != "$LAST_SHOW_RIGHT_PANEL" ]]; then
            printf '\e[2J\e[H'
            LAST_COLS=$cols
            LAST_LINES=$lines
