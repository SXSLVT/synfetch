            printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_CPU" "CPU" "$cpu_print" "$CPU_COLOR"; row=$((row+1))
        fi

        if [[ "${SHOW_GPU:-true}" == true ]]; then
            local gpu_print="${GPU:-}"
            [[ -z "$gpu_print" || "$gpu_print" == "Unknown GPU" ]] && gpu_print=$(get_fallback_gpu)
            while IFS= read -r gpu_line || [[ -n "$gpu_line" ]]; do
                [[ -z "$gpu_line" ]] && continue
                printf '\e[%d;%dH' $((row+1)) 1
                prin "$ICON_GPU" "GPU" "$gpu_line" "$GPU_COLOR"
                row=$((row + 1))
            done <<< "$gpu_print"
        fi

        [[ "${SHOW_RAM:-true}" == true ]] && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_RAM" "RAM" "$(get_ram_info)" "$RAM_COLOR"; row=$((row+1)); }
        [[ "${SHOW_UPTIME:-true}" == true ]] && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_UPTIME" "Uptime" "$(get_uptime)" "$UPTIME_COLOR"; row=$((row+1)); }
        [[ "${SHOW_SHELL:-true}" == true ]]  && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_SHELL"  "Shell"  "$SHELL_NAME"  "$SHELL_COLOR"; row=$((row+1)); }
        [[ "${SHOW_DEWM:-true}" == true ]]   && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_DEWM"   "DE/WM"  "$de_wm"       "$DEWM_COLOR"; row=$((row+1)); }
