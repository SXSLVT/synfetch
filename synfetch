                echo -e " ${SEPARATOR_COLOR}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${RESET}"
                row=$((row + 1))
        fi

        if [[ "$SHOW_RIGHT_PANEL" == true ]]; then
            local right_row=0
            printf '\e[%d;%dH' $((right_row+1)) $((RIGHT_COL+1))
            printf "${C1}   PID  PROGRAM           USER        MEMB    CPU ${RESET}"
            right_row=$((right_row + 1))
            printf '\e[%d;%dH' $((right_row+1)) $((RIGHT_COL+1))
		    printf "${SEPARATOR_COLOR}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${RESET}"
            right_row=$((right_row + 1))
            local _proc_start_row=$right_row

            if [ ${#PROC_PIDS[@]} -eq 0 ]; then
                printf '\e[%d;%dH' $((right_row+1)) $((RIGHT_COL+1))
                printf "${GRAY}No processes                                        ${RESET}"
                right_row=$((right_row + 1))

            else
                for i in "${!PROC_PIDS[@]}"; do
                    printf '\e[%d;%dH' $((right_row+1)) $((RIGHT_COL+1))
                    local mem_display="${PROC_MEMS[$i]}M"
                    local proc_color="${OS_COLOR}"
                    local is_paused=false
                    for p in "${PAUSED_PIDS[@]}"; do
                        [[ "$p" == "${PROC_PIDS[$i]}" ]] && is_paused=true && break
                    done
                    if $is_paused; then
                        proc_color="${GREEN}"
                    elif (( ${PROC_CPUS[$i]%%.*} >= 25 )) || (( ${PROC_MEMS[$i]} >= 1024 )); then
