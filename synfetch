                            printf '\e[%d;%dH' $((help_row + 1)) 1
                            printf '\e[K'
                            printf "${YELLOW}Search (ESC to cancel): ${RESET}${_sq}"
                        elif [[ "$_ch" == $'\e' ]]; then _sq=""; break
                        else _sq+="$_ch"; printf "%s" "$_ch"
                        fi
                    done
                    SEARCH_QUERY="$_sq"
