    NORTH_PADDING=${NORTH_PADDING:-2}

    for ((p=0; p<NORTH_PADDING; p++)); do echo ""; done

    printf '\e[?7l'

    left_lines=()
    $USE_ASCII && mapfile -t left_lines <<< "$left_art"

    _max_left_w=0
    _extglob_was_off=true
    shopt -q extglob && _extglob_was_off=false
    shopt -s extglob
    for _ll in "${left_lines[@]}"; do
        _ll_vis="${_ll//$'\r'/}"
        printf -v _ll_vis '%b' "$_ll_vis"
        _ll_vis="${_ll_vis//$'\e'(B/}"
        _ll_vis="${_ll_vis//$'\e'\[*([0-9;])[a-zA-Z]/}"
        (( ${#_ll_vis} > _max_left_w )) && _max_left_w=${#_ll_vis}
    done
    $_extglob_was_off && shopt -u extglob
    INFO_COL=$(( _max_left_w + 4 ))

    left_len=${#left_lines[@]}
    stat_len=${#stats_lines[@]}

    if (( left_len < stat_len )); then
        pad_top=$(( (stat_len - left_len) / 2 ))
        for ((p=0; p<pad_top; p++)); do left_lines=("" "${left_lines[@]}"); done
    elif (( stat_len < left_len )); then
        pad_top=$(( (left_len - stat_len) / 2 ))
        for ((p=0; p<pad_top; p++)); do stats_lines=("" "${stats_lines[@]}"); done
    fi

    max_rows=$(( ${#left_lines[@]} > ${#stats_lines[@]} ? ${#left_lines[@]} : ${#stats_lines[@]} ))

    for ((i=0; i<max_rows; i++)); do
        left="${left_lines[i]:-}"
        right="${stats_lines[i]:-}"
        left="${left//$'\r'/}"
        printf "%b\e[0m\e[${INFO_COL}G%b\n" "$left" "$right"
    done

    printf '\e[?7h'
fi
fi

# CPU Usage stats cache update
read -r _ u n s i io ir so st _ _ < /proc/stat
printf '%s %s %s %s %s %s %s %s\n' "$u" "$n" "$s" "$i" "$io" "$ir" "$so" "$st" > "$CACHE_DIR/cpu_stat.cache"
