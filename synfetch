get_top_processes() {
    PROC_PIDS=() PROC_USERS=() PROC_CPUS=() PROC_MEMS=() PROC_COMMS=()
    local sort_opt="-%cpu"
    [[ "$SORT_MODE" == "ram" ]] && sort_opt="-%mem"

    local total_mem_mb
    total_mem_mb=$(awk '/MemTotal/ {print int($2/1024)}' /proc/meminfo 2>/dev/null || echo 8192)

    local _ps_out
    _ps_out=$(LC_NUMERIC=C ps -eo pid,user,%cpu,%mem,comm --no-headers --sort="$sort_opt")

    if [[ -n "$SEARCH_QUERY" ]]; then
        _ps_out=$(grep -i -- "$SEARCH_QUERY" <<< "$_ps_out")
    fi

    while read -r pid user cpu mem_percent short_cmd; do
