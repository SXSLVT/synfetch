# Motherboard Detector 
get_mobo_info() {
    local vendor="" name="" version=""

    if [ "$(uname)" = "Darwin" ]; then
        name=$(sysctl -n hw.model 2>/dev/null)
        echo "${name:-Unknown}"
        return
    fi

    [ -r /sys/class/dmi/id/board_vendor ]  && vendor=$(< /sys/class/dmi/id/board_vendor)
    [ -r /sys/class/dmi/id/board_name ]    && name=$(< /sys/class/dmi/id/board_name)
    [ -r /sys/class/dmi/id/board_version ] && version=$(< /sys/class/dmi/id/board_version)

    if [[ -z "$vendor" || "$vendor" == "None" ]]; then
        [ -r /sys/class/dmi/id/sys_vendor ] && vendor=$(< /sys/class/dmi/id/sys_vendor)
    fi
    if [[ -z "$name" || "$name" == "None" ]]; then
        [ -r /sys/class/dmi/id/product_name ] && name=$(< /sys/class/dmi/id/product_name)
    fi

    if [[ -z "$name" || "$name" == "None" ]] && [ -r /sys/firmware/devicetree/base/model ]; then
        name=$(tr -d '\0' < /sys/firmware/devicetree/base/model 2>/dev/null)
    fi

    vendor=$(echo "$vendor" | xargs 2>/dev/null)
    name=$(echo "$name" | xargs 2>/dev/null | sed -E 's/[[:space:]]+[Rr]ev ?[0-9]+(\.[0-9A-Za-z.]*)*$//')
    version=$(echo "$version" | xargs 2>/dev/null)

    vendor=${vendor//QEMU Standard PC/QEMU}
    name=${name//Standard PC \(i440FX + PIIX, 1996\)/QEMU VM}

    local junk_regex="^(None|To [Bb]e [Ff]illed [Bb]y O\.E\.M\.|Default string|System Product Name|System Version|OEM|Not Applicable|Not Available|N\/A|Unknown|INVALID|Type1ProductConfigId|Base Board Product Name|System board|All Series|FFFFFFFF|[0-9]{1,3}\.[0-9]{1,3}|[[:space:]]*)$"

    [[ "$vendor"  =~ $junk_regex ]] && vendor=""
    [[ "$name"    =~ $junk_regex ]] && name=""
    [[ "$version" =~ $junk_regex ]] && version=""

    local ver_junk_regex="^([Rr]ev )?[Xx]\.[0-9][0-9A-Za-z]*$|^[0-9]+(\.[0-9A-Za-z]+)*$|^[Rr]ev [0-9A-Za-z.]+$"
    [[ "$version" =~ $ver_junk_regex ]] && version=""

    if [[ -n "$version" && -n "$name" && "$name" != *"$version"* ]]; then
        name="$name $version"
    fi
    
    if [[ -n "$vendor" && -n "$name" ]]; then
        if [[ "${name^^}" == *"${vendor^^}"* ]]; then
            echo "$name"
        else
            echo "$vendor $name"
        fi
    elif [[ -n "$name" ]]; then
        echo "$name"
    elif [[ -n "$vendor" ]]; then
        echo "$vendor"
    else
        echo "Unknown"
    fi
}

