    tput rc
    tput el

    case "$kkey" in
        t|T) kill -15 "$pid" 2>/dev/null; tput cup "$msg_row" "$msg_col"; printf "${GREEN}SIGTERM sent!${RESET}"; sleep 0.8 ;;
        9)   kill -9  "$pid" 2>/dev/null; tput cup "$msg_row" "$msg_col"; printf "${RED}SIGKILL sent!${RESET}"; sleep 0.8 ;;
        *)   return ;;
    esac
    tput cup "$msg_row" "$msg_col"
    tput el
}

pause_selected() {
    local pid="${PROC_PIDS[$SELECTED]:-}"
    if [[ -z "$pid" || "$pid" == "PID" ]]; then return; fi
    local cmd="${PROC_COMMS[$SELECTED]:0:40}"
    local msg_row=$(( $(tput lines) - 3 ))
    local msg_col=5

    tput cup "$msg_row" "$msg_col"
    tput el
    tput sc

    local is_paused=false
    for p in "${PAUSED_PIDS[@]}"; do
        [[ "$p" == "$pid" ]] && is_paused=true && break
    done

    if $is_paused; then
	    printf "${C1}Resume PID %s [%s]? (y)es${RESET}" "$pid" "$cmd"
    else
	    printf "${C1}Pause PID %s [%s]? (y)es${RESET}" "$pid" "$cmd"
    fi

    local kkey=""
    read -t 5 -n 1 -s kkey 2>/dev/null || true
    tput rc
    tput el

    if [[ "$kkey" == "y" || "$kkey" == "Y" ]]; then
        if $is_paused; then
            kill -CONT "$pid" 2>/dev/null
            local -a new=()
            for p in "${PAUSED_PIDS[@]}"; do
                [[ "$p" != "$pid" ]] && new+=("$p")
            done
            PAUSED_PIDS=("${new[@]}")
        else
            kill -STOP "$pid" 2>/dev/null
            PAUSED_PIDS+=("$pid")
        fi
    fi

    tput cup "$msg_row" "$msg_col"
    tput el
}

synfetch_live() {
    clear
    printf '\e[?25l'
    stty -icanon -echo
    trap 'printf "\e[?25h\e[2J\e[H"; stty sane; clear; exit 0' INT EXIT

    PAUSED_PIDS=()           
    local LAST_COLS=0
    local LAST_LINES=0
    local WAS_TOO_SMALL=false
    local SHOW_RIGHT_PANEL=true
    local LAST_SHOW_RIGHT_PANEL=true
    local cpu_update_counter=0
    local CPU_UPDATE_EVERY=3

    while true; do
        local size
        size=$(stty size 2>/dev/null || echo "24 80")
        local lines=${size%% *}
        local cols=${size##* }

        [[ -z "$cols" || "$cols" -lt 20 ]] && cols=80
        [[ -z "$lines" || "$lines" -lt 5 ]] && lines=24

        if (( cols < 120 || lines < 26 )); then
