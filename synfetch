        if (( RIGHT_COL < 62 + MIN_GAP )); then
            RIGHT_COL=$((62 + MIN_GAP))
        fi

        if (( cpu_update_counter % CPU_UPDATE_EVERY == 0 )); then
        CPU=$(get_cpu_usage 2>/dev/null || echo 0)
        fi
        cpu_update_counter=$((cpu_update_counter + 1))
       	RAM=$(get_ram_usage 2>/dev/null || echo 0)
        GPU_USAGE=$(get_gpu_usage 2>/dev/null || echo 0)
        get_top_processes

