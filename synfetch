		    right_row=$((right_row + 1))
                done
            fi

            while (( right_row < _proc_start_row + MAX_PROCS + 2 )); do
                printf '\e[%d;%dH' $((right_row+1)) $((RIGHT_COL+1))
                printf '\e[K'
