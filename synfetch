        [[ "${SHOW_KERNEL:-true}" == true ]] && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_KERNEL" "Kernel" "$KERNEL"      "$KERNEL_COLOR"; row=$((row+1)); }
        [[ "${SHOW_USER:-true}" == true ]]   && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_USER"   "User"   "$USER"        "$USER_COLOR"; row=$((row+1)); }
        [[ "${SHOW_HOST:-true}" == true ]]   && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_HOST"   "Host"   "$HOSTNAME"    "$HOST_COLOR"; row=$((row+1)); }

        if [[ "${SHOW_MOBO:-true}" == true ]]; then
