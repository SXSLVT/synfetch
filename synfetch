                "s"|"S")
                    local _sq=""
                    printf '\e[%d;%dH' $((help_row + 1)) 1
                    printf '\e[K'
                    printf "${YELLOW}Search (ESC to cancel): ${RESET}"
                    while true; do
                        local _ch
                        read -r -s -n 1 _ch
                        if [[ "$_ch" == "" ]]; then break
                        elif [[ "$_ch" == $'\x7f' || "$_ch" == $'\b' ]]; then
