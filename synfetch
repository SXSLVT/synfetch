# Hex color
hex_to_ansi() {
    local hex="${1#\#}"
    if [[ "$hex" =~ ^[0-9a-fA-F]{6}$ ]]; then
        local r=$((16#${hex:0:2}))
        local g=$((16#${hex:2:2}))
        local b=$((16#${hex:4:2}))
        printf "\e[38;2;%d;%d;%dm" "$r" "$g" "$b"
    else
        printf "\e[38;5;51m"  # fallback cyan
    fi
}

