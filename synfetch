            printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_MOBO" "MoBo" "$mobo_print" "$MOBO_COLOR"; row=$((row+1))
        fi

        if [[ "${SHOW_CPU:-true}" == true ]]; then
            local cpu_print="${CPU_MODEL:-}"
