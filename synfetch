# GPU & GPU Usage Detector
get_gpu() {
    local gpu_list=()

    if command -v lspci >/dev/null 2>&1; then
        while read -r line; do
            [ -n "$line" ] && gpu_list+=("$line")
        done < <(lspci 2>/dev/null | grep -E "VGA|3D|Display" | sed '
            s/^.*: //;                        
            s/ \[AMD\/ATI\]//g;          
            s/Advanced Micro Devices, Inc\./AMD/g;
            s/Advanced Micro Devices/AMD/g;
            s/ (rev .*)$//;
            s/Corporation //g;
            s/Inc\. //g;
            s/Computer //g;
            s/Device .*//g;
            s/VGA compatible controller //gi;
            s/3D controller //gi;
            s/Display controller //gi;
            s/ASUSTeK//gi;
            s/^ //; s/ $//;
        ' | awk '!seen[$0]++')
    fi

    if command -v nvidia-smi >/dev/null 2>&1; then
       local nvidia_name _nv_rc
        nvidia_name=$(nvidia-smi --query-gpu=name --format=csv,noheader,nounits 2>/dev/null | head -n1)
        _nv_rc=${PIPESTATUS[0]}
        if [[ "$_nv_rc" -eq 0 && -n "$nvidia_name" ]]; then
	    local found_nv=false
            for i in "${!gpu_list[@]}"; do
                if [[ "${gpu_list[$i]}" == *NVIDIA* || "${gpu_list[$i]}" == *GeForce* || "${gpu_list[$i]}" == *RTX* || "${gpu_list[$i]}" == *Quadro* ]]; then
                    gpu_list[$i]="NVIDIA ${nvidia_name#NVIDIA }"
                    found_nv=true
                fi
            done
            [[ "$found_nv" == false ]] && gpu_list+=("NVIDIA ${nvidia_name#NVIDIA }")
        fi
    fi

    if [ ${#gpu_list[@]} -eq 0 ]; then
        for card in /sys/class/drm/card*/device/vendor; do
            [ -f "$card" ] || continue
            case "$(cat "$card" 2>/dev/null)" in
                0x10de) gpu_list+=("NVIDIA GPU") ;;
                0x1002) gpu_list+=("AMD GPU") ;;
                0x8086) gpu_list+=("Intel GPU") ;;
            esac
        done
    fi

    if [ ${#gpu_list[@]} -gt 0 ]; then
        printf '%s\n' "${gpu_list[@]}" | sort -u
    else
        echo "Unknown GPU"
    fi
}

get_gpu_usage() {
    if [ "$(uname)" != "Linux" ]; then
        echo "N/A"
        return
    fi

    if command -v nvidia-smi >/dev/null 2>&1; then
        local usage
        usage=$(nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null | head -n1 | tr -d ' %')
        if [[ "$usage" =~ ^[0-9]+$ ]]; then
            echo "$usage"
            return
        fi
    fi

    local amdgpu_found=false
    local amdgpu_usage=0
    for card in /sys/class/drm/card*/device/gpu_busy_percent; do
        if [ -f "$card" ]; then
            amdgpu_found=true
            local val
            val=$(cat "$card" 2>/dev/null)
            if [[ "$val" =~ ^[0-9]+$ ]] && (( val > amdgpu_usage )); then
                amdgpu_usage=$val
            fi
        fi
    done
    if $amdgpu_found; then
        echo "$amdgpu_usage"
        return
    fi

    if command -v intel_gpu_top >/dev/null 2>&1; then
        local usage
        usage=$(timeout 0.2s intel_gpu_top -s 100 -o - 2>/dev/null \
                | sed -n 's/.*"Render\/3D\/[0-9]*":{"busy":\([0-9]*\(\.[0-9]*\)\?\).*/\1/p' \
                | awk 'NR==1{printf "%d", $1+0.5}')

        if [[ "$usage" =~ ^[0-9]+$ ]]; then
            echo "$usage"
            return
        fi
    fi

    echo "0"
}

# CPU Model Detector
get_cpu_model() {
    if [ "$(uname)" = "Darwin" ]; then
        sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "Unknown CPU"
        return
    fi

    if [ -r /proc/cpuinfo ]; then
        local model threads
        model=$(awk -F': ' '/^model name/ {print $2; exit}' /proc/cpuinfo 2>/dev/null)
        threads=$(nproc 2>/dev/null || grep -c ^processor /proc/cpuinfo 2>/dev/null)

        if [ -n "$model" ]; then
            model=$(echo "$model" | sed -E 's/[[:space:]-]*[0-9]+-Core.*//gi; s/@.*//g; s/\(R\)|\(TM\)//gi; s/[[:space:]]{2,}/ /g; s/^[[:space:]]*//; s/[[:space:]]*$//')
            echo "$model ($threads)"
            return
        fi
    fi
    echo "Unknown CPU"
}

# Package Detector
pkg_count() {
    local pkgs=()
    local count

    if command -v dpkg >/dev/null; then
        if [[ -r /var/lib/dpkg/status ]]; then
            count=$(grep -c '^Package: ' /var/lib/dpkg/status 2>/dev/null)
        else
            count=$(dpkg-query -f '${binary:Package}\n' -W 2>/dev/null | wc -l)
        fi
        pkgs+=("$count (dpkg)")
    elif command -v rpm >/dev/null; then
        count=$(rpm -qa --nodigest --nosignature 2>/dev/null | wc -l)
        pkgs+=("$count (rpm)")
    elif command -v apk >/dev/null; then
        count=$(apk info -q 2>/dev/null | wc -l)
        pkgs+=("$count (apk)")
    elif command -v xbps-query >/dev/null; then
        count=$(xbps-query -l 2>/dev/null | wc -l)
        pkgs+=("$count (xbps)")
    elif command -v qlist >/dev/null; then
        count=$(qlist -I 2>/dev/null | wc -l)
        pkgs+=("$count (emerge)")
    elif command -v slackpkg >/dev/null || [ -d /var/log/packages ]; then
        count=$(ls /var/log/packages/ 2>/dev/null | wc -l)
        pkgs+=("$count (slackware)")
    elif command -v brew >/dev/null; then
        local formulas=$(brew list --formula 2>/dev/null | wc -l)
        local casks=$(brew list --cask 2>/dev/null | wc -l)
        pkgs+=("$formulas (formulas) + $casks (casks) = $((formulas + casks)) (brew)")
    elif command -v port >/dev/null; then
        count=$(port -q installed 2>/dev/null | wc -l)
        pkgs+=("$count (MacPorts)")
    elif command -v pkgutil >/dev/null || command -v pkg >/dev/null; then
        count=$(pkgutil --pkgs 2>/dev/null | wc -l)
        pkgs+=("$count (Fink/pkgutil)")
    elif command -v pacman >/dev/null; then
        count=$(pacman -Qq 2>/dev/null | wc -l)
        pkgs+=("$count (pacman)")
    elif ls /Programs >/dev/null 2>&1; then
        count=$(ls /Programs 2>/dev/null | wc -l)
        pkgs+=("$count (programs)")
    fi
    if command -v nix-store >/dev/null; then
        local nix_count
        nix_count=$(timeout 2s nix-store -q --requisites /run/current-system 2>/dev/null | wc -l)
        (( nix_count > 0 )) && pkgs+=("$nix_count (nix)")
    fi
    if command -v guix >/dev/null; then
        local guix_user guix_sys guix_total
        guix_user=$(timeout 2s guix package --profile="${HOME}/.guix-profile" --list-installed 2>/dev/null | wc -l)
        guix_sys=0
        [ -f /run/current-system/profile/manifest ] && \
            guix_sys=$(timeout 2s guix package --list-installed --profile=/run/current-system/profile 2>/dev/null | wc -l)
        guix_total=$(( guix_user + guix_sys ))
        (( guix_total > 0 )) && pkgs+=("$guix_total (guix)")
    fi
    if command -v flatpak >/dev/null; then
        local fp_count=$(flatpak list --columns=application 2>/dev/null | wc -l)
        if [ "$fp_count" -gt 0 ]; then
            pkgs+=("$fp_count (flatpak)")
        fi
    fi

    if [ ${#pkgs[@]} -eq 0 ]; then
        echo "?"
    else
        local out
        printf -v out '%s, ' "${pkgs[@]}"
        echo "${out%, }"
    fi
}

