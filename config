# Available themes: synthwave (default), monochrome, minimal, dracula, nord, catppuccin, tokyonight, gruvbox, custom, automatic
# Available distros: arch, cachyos, ubuntu, debian, devuan, fedora, linuxmint, zorinos, popos, manjaro, opensuse, slackware, centos, redhat, mxlinux, guix, qubesos, antix, garuda, nobara, bazzite, kali, elementaryos, kdeneon, deepin, alpine, gobo, lfs, gentoo, endeavouros, artix, void, bedrock, bodhi, nixos, blackarch, arco, archcraft, puppy, parrotos, peppermint, parabola, steamos, tails, pikaos, chimera, macos

# Set theme to "automatic", if you use pywal, matugen or any color scheme generator
# Set theme to "custom" to use the hex colors below
THEME="synthwave"

# Custom hex colors (rainbow gradient by default, edit any line to taste)
C1_HEX="#e25a5a"            # ASCII Art
OS_HEX="#e28a5a"            # OS
KERNEL_HEX="#e2ba5a"        # Kernel
USER_HEX="#dae25a"          # User
HOST_HEX="#aae25a"          # Hostname
MOBO_HEX="#7ae25a"          # Motherboard
CPU_HEX="#5ae26a"           # CPU
GPU_HEX="#5ae29a"           # GPU
RAM_HEX="#5ae2ca"           # RAM
UPTIME_HEX="#5acae2"        # Uptime
SHELL_HEX="#5a9ae2"         # Shell
DEWM_HEX="#5a6ae2"          # DE/WM
PKGS_HEX="#7a5ae2"          # Packages
COLORS_HEX="#aa5ae2"        # Color palette
BAR_LABEL_HEX="#da5ae2"     # Bar label
BAR_FILLED1_HEX="#e25aba"   # Filled bar 1
BAR_FILLED2_HEX="#e25a8a"   # Filled bar 2
BAR_EMPTY_HEX="#282a36"     # Empty bar
SEPARATOR_HEX="#444b6a"     # Separator

# Show/Hide modules
SHOW_OS=true
SHOW_KERNEL=true
SHOW_USER=true
SHOW_HOST=true
SHOW_MOBO=true
SHOW_CPU=true
SHOW_GPU=true
SHOW_RAM=true
SHOW_UPTIME=true
SHOW_SHELL=true
SHOW_DEWM=true
SHOW_PKGS=true
SHOW_COLOR_PALETTE=true
SHOW_USAGE_BARS=true

# Show/Hide all modules except the ASCII text
HIDE_INFO=false

# Toggle ASCII
USE_ASCII=true

# Toggle icons
USE_NERD_FONTS=true

# Toggle between Fastfetch side-by-side (false) or classic Nitch top-banner (true)
NITCH_LIKE=false

# Use a different distro ASCII art (leave empty for default distro)
CUSTOM_DISTRO="" 

# Custom ASCII text rendered in small slant font (leave empty to use distro logo)
# Requires figlet.
CUSTOM_TEXT=""

# Toggle Live mode on startup
LIVE_MODE=false
